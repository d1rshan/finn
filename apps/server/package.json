{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "cron:run": "tsx src/scripts/run-cron.ts",
    "cron:hourly": "tsx src/scripts/run-cron.ts hourly",
    "cron:briefing": "tsx src/scripts/run-cron.ts briefing",
    "cron:weekly": "tsx src/scripts/run-cron.ts weekly",
    "cron:monthly": "tsx src/scripts/run-cron.ts monthly",
    "cron:cleanup": "tsx src/scripts/run-cron.ts cleanup",
    "cron:behavior": "tsx src/scripts/run-cron.ts behavior",
    "cron:refresh-user": "tsx src/scripts/run-cron.ts refresh-user",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@ai-sdk/google": "catalog:",
    "@finn/auth": "workspace:*",
    "@finn/db": "workspace:*",
    "@finn/env": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@finn/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.16.5",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}
